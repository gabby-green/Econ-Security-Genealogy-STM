# =============================================================================
# Topic Exploration Script
# =============================================================================
library(here)
source(here("01_Scripts", "00_configuration.R"))
library(dplyr)
library(stm)
# =============================================================================
# CONFIGURATION - CHANGE THESE
# =============================================================================
corpus <- "EU"
topic_num <- 12
n_docs <- 10
# =============================================================================
# LOAD MODELS
# =============================================================================
if (corpus == "US") {
stm_model <- readRDS(here("03_STM_Outputs", "US", "us_stm_model_k20.rds"))
out <- readRDS(here("03_STM_Outputs", "US", "us_stm_preprocessed.rds"))
k <- 20
} else {
stm_model <- readRDS(here("03_STM_Outputs", "EU", "eu_stm_model_k15.rds"))
out <- readRDS(here("03_STM_Outputs", "EU", "eu_stm_preprocessed.rds"))
k <- 15
}
# =============================================================================
# TOPIC WORDS
# =============================================================================
cat("\n========== ", corpus, " TOPIC ", topic_num, " ==========\n\n", sep = "")
labels <- labelTopics(stm_model, topics = topic_num, n = 15)
cat("PROB:  ", paste(labels$prob[topic_num,], collapse = ", "), "\n\n")
cat("FREX:  ", paste(labels$frex[topic_num,], collapse = ", "), "\n\n")
cat("LIFT:  ", paste(labels$lift[topic_num,], collapse = ", "), "\n\n")
cat("SCORE: ", paste(labels$score[topic_num,], collapse = ", "), "\n\n")
# =============================================================================
# TOP DOCUMENTS
# =============================================================================
cat("---------- TOP DOCUMENTS ----------\n\n")
thoughts <- findThoughts(stm_model, texts = out$meta$file_name, n = n_docs, topics = topic_num)
doc_indices <- thoughts$index[[1]]
doc_summary <- data.frame(
Rank = 1:length(doc_indices),
Document = out$meta$file_name[doc_indices],
Year = out$meta$year[doc_indices],
Proportion = round(stm_model$theta[doc_indices, topic_num], 3)
)
print(doc_summary, row.names = FALSE)
# =============================================================================
# TEXT EXCERPTS
# =============================================================================
cat("\n---------- TEXT EXCERPTS ----------\n")
for (i in 1:min(10, length(doc_indices))) {
doc_name <- out$meta$file_name[doc_indices[i]]
filepath <- here("00_Corpus", paste0(doc_name, ".txt"))
if (file.exists(filepath)) {
text <- readLines(filepath, warn = FALSE) %>% paste(collapse = " ")
text <- gsub("\\s+", " ", text)
excerpt <- substr(text, 1, 600)
cat("\n[", i, "] ", doc_name, " (", out$meta$year[doc_indices[i]], ")\n", sep = "")
cat(strwrap(excerpt, width = 80), sep = "\n")
cat("...\n")
}
}
# =============================================================================
# DISTRIBUTIONS (top 90th percentile documents)
# =============================================================================
threshold <- quantile(stm_model$theta[, topic_num], 0.9)
high_docs <- which(stm_model$theta[, topic_num] > threshold)
cat("\n---------- YEAR DISTRIBUTION ----------\n\n")
print(table(out$meta$year[high_docs]))
cat("\n---------- DOCUMENT TYPE DISTRIBUTION ----------\n\n")
if ("document_type" %in% names(out$meta)) {
print(table(out$meta$document_type[high_docs]))
} else {
cat("document_type not found in metadata\n")
}
cat("\n---------- SUB-INSTITUTION DISTRIBUTION ----------\n\n")
if ("sub_institution" %in% names(out$meta)) {
print(table(out$meta$sub_institution[high_docs]))
} else {
cat("sub_institution not found in metadata\n")
}
cat("\n")
# Which topics do recent TDRs load on?
tdr_docs <- grep("EC_TDR", out$meta$file_name)
tdr_theta <- stm_model$theta[tdr_docs, ]
rownames(tdr_theta) <- out$meta$file_name[tdr_docs]
round(tdr_theta, 3)
# Topic 3 - what non-TDR documents load highly?
topic3_props <- stm_model$theta[, 3]
top_topic3 <- order(topic3_props, decreasing = TRUE)[1:20]
data.frame(
Document = out$meta$file_name[top_topic3],
Year = out$meta$year[top_topic3],
DocType = out$meta$document_type[top_topic3],
Proportion = round(topic3_props[top_topic3], 3)
)
# =============================================================================
# TDR Stopword Robustness Check Script
# =============================================================================
library(here)
source(here("01_Scripts", "00_configuration.R"))
cat("\n========== TDR STOPWORD ROBUSTNESS CHECK ==========\n\n")
# Define procedural/legal terms from Topics 3 and 12 to test as stopwords
# These are genre-specific, not substantively meaningful
tdr_stopwords <- c(
# Legal/procedural from Topic 12
"articl", "communiti", "expiri", "interim", "refund", "termin",
"cfi", "coj", "com", "newcom", "judgment", "absorpt",
"analogu", "subgroup", "hereaft", "amend",
# Administrative from Topic 3
"sfg", "sfgs", "investig", "initiat", "imposit", "review"
)
cat("Adding", length(tdr_stopwords), "TDR-specific stopwords:\n")
cat(paste(tdr_stopwords, collapse = ", "), "\n\n")
# Combine with existing stopwords
custom_stops_extended <- c(custom_stops, tdr_stopwords)
# Load full corpus
corpus_all <- load_corpus()
corpus_eu <- corpus_all %>% filter(institution == "EU")
# =============================================================================
# Modified preprocessing function with extended stopwords
# =============================================================================
preprocess_corpus_extended <- function(corpus_data, phrases, stopwords_extra, min_docfreq = 5, min_nchar = 3) {
corpus_data <- corpus_data %>%
mutate(
text = str_replace_all(text, "https?://[^\\s]+", ""),
text = str_replace_all(text, "www\\.[^\\s]+", ""),
text = str_replace_all(text, "={2,}", " "),
text = str_replace_all(text, "(?i)\\bU\\.?S\\.?C\\.?\\b", "united_states_code"),
text = str_replace_all(text, "(?i)\\bU\\.?\\s?S\\.?\\b", "united_states"),
text = str_replace_all(text, "(?i)\\bE\\.?U\\.?\\b", "european_union"),
text = str_replace_all(text, "(?i)\\bW\\.?T\\.?O\\.?\\b", "world_trade_organization"),
text = str_replace_all(text, "(?i)\\bP\\.?R\\.?C\\.?\\b", "china"),
text = str_replace_all(text, "(?i)\\bI\\.?C\\.?T\\.?\\b", "information_communications_technology"),
text = str_replace_all(text, "(?i)\\bxi\\s+jinping\\b", "xijinping"),
text = str_replace_all(text, "(?i)\\bli\\s+keqiang\\b", "likeqiang"),
text = str_replace_all(text, "\u2018|\u2019", "'"),
text = str_replace_all(text, "\u201C|\u201D", '"'),
text = str_replace_all(text, "\u2014|\u2013", "-"),
text = str_replace_all(text, "ö", "o"),
text = str_replace_all(text, "Ã¶", "o"),
text = str_replace_all(text, "ï", "i"),
text = str_replace_all(text, "Ã¯", "i"),
text = str_replace_all(text, "naïve", "naive"),
text = str_replace_all(text, "'s\\b", ""),
text = str_replace_all(text, "s'\\b", "s"),
text = str_replace_all(text, "'\\b", ""),
text = str_replace_all(text, "`", ""),
text = str_replace_all(text, "'{2,}", ""),
text = str_replace_all(text, "\\.{2,}", " "),
text = str_replace_all(text, "(?i)\\be\\.?g\\.?\\b", ""),
text = str_replace_all(text, "(?i)\\bi\\.?e\\.?\\b", "")
)
qcorpus <- corpus(corpus_data, text_field = "text")
toks <- tokens(qcorpus, remove_punct = TRUE, remove_numbers = TRUE,
remove_symbols = TRUE, remove_url = TRUE) %>%
tokens_tolower() %>%
tokens_compound(pattern = phrase(phrases), concatenator = "_") %>%
tokens_remove(stopwords("en")) %>%
tokens_remove(stopwords_extra) %>%
tokens_wordstem() %>%
tokens_select(min_nchar = min_nchar)
dfm_corpus <- dfm(toks) %>%
dfm_trim(min_docfreq = min_docfreq)
out <- convert(dfm_corpus, to = "stm")
out$meta <- corpus_data
return(out)
}
# Preprocess with extended stopwords
cat("Preprocessing with extended stopwords...\n")
out_extended <- preprocess_corpus_extended(corpus_eu, phrases_eu_full, custom_stops_extended)
# Run STM
cat("Running STM (K=15)...\n\n")
stm_extended <- stm(documents = out_extended$documents,
vocab = out_extended$vocab,
K = 15,
prevalence = ~ year,
data = out_extended$meta,
seed = 12345,
verbose = FALSE)
# =============================================================================
# OUTPUT: Topic Words Comparison
# =============================================================================
cat("========== TOPIC WORDS (EXTENDED STOPWORDS MODEL) ==========\n\n")
for (i in 1:15) {
labels <- labelTopics(stm_extended, topics = i, n = 10)
cat("Topic", i, "FREX:", paste(labels$frex[i,], collapse = ", "), "\n")
}
# =============================================================================
# OUTPUT: Model Quality Metrics
# =============================================================================
cat("\n========== MODEL QUALITY METRICS ==========\n\n")
stm_original <- readRDS(here("03_STM_Outputs", "EU", "eu_stm_model_k15.rds"))
out_original <- readRDS(here("03_STM_Outputs", "EU", "eu_stm_preprocessed.rds"))
sem_orig <- semanticCoherence(stm_original, out_original$documents)
excl_orig <- exclusivity(stm_original)
sem_ext <- semanticCoherence(stm_extended, out_extended$documents)
excl_ext <- exclusivity(stm_extended)
cat("ORIGINAL MODEL:\n")
cat("  Mean Coherence:", round(mean(sem_orig), 2), "\n")
cat("  Mean Exclusivity:", round(mean(excl_orig), 2), "\n")
cat("  Vocab size:", length(out_original$vocab), "\n\n")
cat("EXTENDED STOPWORDS MODEL:\n")
cat("  Mean Coherence:", round(mean(sem_ext), 2), "\n")
cat("  Mean Exclusivity:", round(mean(excl_ext), 2), "\n")
cat("  Vocab size:", length(out_extended$vocab), "\n\n")
# =============================================================================
# OUTPUT: Key Vocabulary Check
# =============================================================================
cat("========== KEY VOCABULARY DISTRIBUTION ==========\n\n")
key_terms <- c("economic_secur", "de-risk", "decoupl", "level_playing_field",
"overcapac", "resili", "strateg", "autonom", "tdi", "trade_def")
cat("Key terms in top 20 FREX:\n\n")
all_frex_ext <- labelTopics(stm_extended, n = 20)$frex
for (term in key_terms) {
topics_with_term <- which(apply(all_frex_ext, 1, function(x) any(grepl(term, x))))
if (length(topics_with_term) > 0) {
cat(term, "-> Topics:", paste(topics_with_term, collapse = ", "), "\n")
} else {
cat(term, "-> Not in top 20 FREX\n")
}
}
# =============================================================================
# OUTPUT: TDR Document Distribution
# =============================================================================
cat("\n========== TDR DOCUMENT DISTRIBUTION ==========\n\n")
tdr_indices <- grep("EC_TDR", out_extended$meta$file_name)
tdr_theta <- stm_extended$theta[tdr_indices, ]
cat("TDR documents now load on topics (showing max topic per doc):\n\n")
tdr_max_topics <- apply(tdr_theta, 1, which.max)
tdr_max_props <- apply(tdr_theta, 1, max)
tdr_summary <- data.frame(
Document = out_extended$meta$file_name[tdr_indices],
Year = out_extended$meta$year[tdr_indices],
Max_Topic = tdr_max_topics,
Max_Prop = round(tdr_max_props, 3)
)
print(tdr_summary[order(tdr_summary$Year), ], row.names = FALSE)
cat("\nTDR topic distribution summary:\n")
print(table(tdr_max_topics))
cat("\n========== END ROBUSTNESS CHECK ==========\n")
# Run model without TDRs
corpus_eu_no_tdr <- corpus_all %>%
filter(institution == "EU", !grepl("EC_TDR", file_name))
cat("EU corpus without TDRs:", nrow(corpus_eu_no_tdr), "documents\n")
out_no_tdr <- preprocess_corpus(corpus_eu_no_tdr, phrases_eu_full)
stm_no_tdr <- stm(documents = out_no_tdr$documents,
vocab = out_no_tdr$vocab,
K = 13,  # Reduced k since fewer docs
prevalence = ~ year,
data = out_no_tdr$meta,
seed = 12345,
verbose = FALSE)
# Compare topic words
for (i in 1:13) {
labels <- labelTopics(stm_no_tdr, topics = i, n = 10)
cat("Topic", i, "FREX:", paste(labels$frex[i,], collapse = ", "), "\n")
}
# Check year coverage without TDRs
corpus_eu_no_tdr %>%
count(year) %>%
print(n = 30)
# Quick robustness check for no-TDR model
cat("========== NO-TDR MODEL ROBUSTNESS ==========\n\n")
# Model quality metrics
sem_no_tdr <- semanticCoherence(stm_no_tdr, out_no_tdr$documents)
excl_no_tdr <- exclusivity(stm_no_tdr)
cat("NO-TDR MODEL (K=13):\n")
cat("  Mean Coherence:", round(mean(sem_no_tdr), 2), "\n")
cat("  Mean Exclusivity:", round(mean(excl_no_tdr), 2), "\n\n")
cat("ORIGINAL MODEL (K=15):\n")
cat("  Mean Coherence:", round(mean(sem_orig), 2), "\n")
cat("  Mean Exclusivity:", round(mean(excl_orig), 2), "\n\n")
# Seed stability check - run with different seeds
cat("Seed stability check...\n\n")
seeds <- c(12345, 54321, 99999)
key_terms <- c("economic_secur", "de-risk", "level_playing_field")
for (s in seeds) {
stm_test <- stm(documents = out_no_tdr$documents,
vocab = out_no_tdr$vocab,
K = 13,
prevalence = ~ year,
data = out_no_tdr$meta,
seed = s,
verbose = FALSE)
all_frex <- labelTopics(stm_test, n = 20)$frex
cat("Seed", s, "- Key terms in FREX:\n")
for (term in key_terms) {
topics <- which(apply(all_frex, 1, function(x) any(grepl(term, x))))
cat("  ", term, "-> Topic(s):", paste(topics, collapse = ", "), "\n")
}
cat("\n")
}
# Check US corpus document types
corpus_us <- corpus_all %>% filter(institution == "US")
# Look for report-type documents
corpus_us %>%
filter(grepl("Report|Annual|TDR", document_type, ignore.case = TRUE) |
grepl("_R_|_AR_|_RPT", file_name)) %>%
select(file_name, year, document_type) %>%
print(n = 50)
# Or just check document type distribution
corpus_us %>%
count(document_type) %>%
print(n = 20)
# Load US model
stm_us <- readRDS(here("03_STM_Outputs", "US", "us_stm_model_k20.rds"))
out_us <- readRDS(here("03_STM_Outputs", "US", "us_stm_preprocessed.rds"))
# Find report indices
report_indices <- grep("TAR_|RCCWTOC_", out_us$meta$file_name)
# Check topic loadings
report_theta <- stm_us$theta[report_indices, ]
rownames(report_theta) <- out_us$meta$file_name[report_indices]
# Show max topic and proportion for each report
report_summary <- data.frame(
Document = out_us$meta$file_name[report_indices],
Year = out_us$meta$year[report_indices],
Max_Topic = apply(report_theta, 1, which.max),
Max_Prop = round(apply(report_theta, 1, max), 3)
)
print(report_summary[order(report_summary$Year), ], row.names = FALSE)
# Topic distribution
cat("\nReport topic distribution:\n")
print(table(report_summary$Max_Topic))
# Load original model
stm_original <- readRDS(here("03_STM_Outputs", "EU", "eu_stm_model_k15.rds"))
out_original <- readRDS(here("03_STM_Outputs", "EU", "eu_stm_preprocessed.rds"))
# Topic 3 and 12 - what non-TDR docs contributed?
cat("========== ORIGINAL TOPIC 3 (New TDR style) ==========\n\n")
t3_props <- stm_original$theta[, 3]
t3_top <- order(t3_props, decreasing = TRUE)[1:20]
t3_docs <- data.frame(
Document = out_original$meta$file_name[t3_top],
Year = out_original$meta$year[t3_top],
Prop = round(t3_props[t3_top], 3),
Is_TDR = grepl("EC_TDR", out_original$meta$file_name[t3_top])
)
print(t3_docs)
cat("\nNon-TDR documents in Topic 3 top 20:", sum(!t3_docs$Is_TDR), "\n")
cat("\n========== ORIGINAL TOPIC 12 (Old TDR style) ==========\n\n")
t12_props <- stm_original$theta[, 12]
t12_top <- order(t12_props, decreasing = TRUE)[1:20]
t12_docs <- data.frame(
Document = out_original$meta$file_name[t12_top],
Year = out_original$meta$year[t12_top],
Prop = round(t12_props[t12_top], 3),
Is_TDR = grepl("EC_TDR", out_original$meta$file_name[t12_top])
)
print(t12_docs)
cat("\nNon-TDR documents in Topic 12 top 20:", sum(!t12_docs$Is_TDR), "\n")
# Check where key TDI policy docs go in no-TDR model
key_docs <- c("EC_PR_071016", "EC_COM_181016")
for (doc in key_docs) {
idx <- which(out_no_tdr$meta$file_name == doc)
if (length(idx) > 0) {
props <- round(stm_no_tdr$theta[idx, ], 3)
top3 <- order(props, decreasing = TRUE)[1:3]
cat(doc, ":\n")
cat("  Topic", top3[1], "(", props[top3[1]], "), Topic", top3[2], "(", props[top3[2]], "), Topic", top3[3], "(", props[top3[3]], ")\n\n")
}
}
